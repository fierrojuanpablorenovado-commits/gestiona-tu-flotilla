# ─────────────────────────────────────────────────────────────────────────────
# Gestiona tu Flotilla — Variables de entorno
# Copia este archivo como .env.local y llena los valores reales
# ─────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_NAME="Gestiona tu Flotilla"
NEXT_PUBLIC_APP_VERSION="2.0.0"

# ─── MODO DEMO (sin Supabase) ─────────────────────────────────────────────────
# Si las variables de Supabase NO están presentes, la app usa datos mock.
# Perfecto para demos locales y el deploy de Vercel de demostración.

# ─── MODO PRODUCCIÓN (con Supabase) ──────────────────────────────────────────
# 1. Crea un proyecto en https://supabase.com/dashboard
# 2. Ve a Project Settings → API
# 3. Copia las siguientes claves:

# URL del proyecto Supabase (requerido para modo producción)
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXX.supabase.co

# Clave anónima pública (segura para el cliente)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Clave de servicio — SOLO EN SERVIDOR, NUNCA EN EL CLIENTE
# Ve a Project Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Storage (Supabase) ───────────────────────────────────────────────────────
# Bucket para archivos adjuntos (fotos, PDFs)
SUPABASE_STORAGE_BUCKET=attachments

# ─── Email (Supabase Auth auto-configura esto) ────────────────────────────────
# Opcional: Si usas un proveedor SMTP externo (SendGrid, Resend, etc.)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.xxx
# SMTP_FROM=no-reply@gestionatuflotilla.mx
