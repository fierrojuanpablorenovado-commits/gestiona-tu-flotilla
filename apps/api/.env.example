# ===========================================
# FleetCore API - Environment Variables
# ===========================================

# Server
PORT=4000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=fleetcore
DB_PASSWORD=fleetcore_dev
DB_NAME=fleetcore_dev
DB_SSL=false
DB_LOGGING=true

# Redis (for job queues)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# File Storage (S3-compatible)
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
# S3_BUCKET=fleetcore-files
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_ENDPOINT=

# Uber API (Supplier Platform)
UBER_CLIENT_ID=
UBER_CLIENT_SECRET=
UBER_ORG_ID=
UBER_API_BASE=https://api.uber.com

# WhatsApp (Evolution API or official)
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_INSTANCE=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@fleetcore.app

# Push Notifications (Expo)
EXPO_ACCESS_TOKEN=

# Encryption key for sensitive data
ENCRYPTION_KEY=your-32-char-encryption-key-here

# Anthropic (Claude AI - Fleet Advisor)
ANTHROPIC_API_KEY=sk-ant-your-key-here
